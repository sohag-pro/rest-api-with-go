# Copy to .env and adjust. All variables are optional.
# The app reads real environment variables, so export them before running:
#   export $(grep -v '^#' .env | xargs) && make run

# Server listen port (1-65535)
PORT=3000

# SQLite database file path
DB_PATH=books.db

# Shared API key for write endpoints (POST/PATCH/DELETE).
# Leave empty to disable auth (all endpoints open).
API_KEY=

# Log level: debug | info | warn | error
LOG_LEVEL=info

# HTTP timeouts and graceful-shutdown grace period (Go duration syntax)
READ_TIMEOUT=10s
WRITE_TIMEOUT=10s
SHUTDOWN_TIMEOUT=10s
